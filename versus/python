"""
NÚCLEO LIMPIO DEL SISTEMA NUMERASO
Un sistema de variables acopladas con controladores automáticos
"""
import math

class Numeraso:
    """
    Implementación limpia del sistema Numeraso.
    Combina N variables con sus controladores en un solo entero.
    """
    
    def __init__(self, base=10, num_variables=3, initial_values=None):
        """
        Inicializa un sistema Numeraso.
        
        Args:
            base: Base numérica (10 para decimal, 2 para binario)
            num_variables: Número de variables en el sistema
            initial_values: Lista de valores iniciales para cada variable
        """
        self.base = base
        self.num_vars = num_variables
        self.ctrl_value = base - 1  # Valor del controlador (9 para decimal, 1 para binario)
        
        # Construir máscaras de posición
        self.var_masks = []
        self.ctrl_masks = []
        
        pos = 1
        for i in range(num_variables):
            self.var_masks.append(pos)
            pos *= base
            
            self.ctrl_masks.append(pos)
            pos *= base
        
        # Inicializar estado
        self.state = 0
        if initial_values:
            for i, val in enumerate(initial_values):
                self._set_variable(i, val)
                self._set_controller(i, self.ctrl_value)
    
    def _get_variable(self, index):
        """Obtiene el valor de una variable específica."""
        return (self.state // self.var_masks[index]) % self.base
    
    def _set_variable(self, index, value):
        """Establece el valor de una variable."""
        # Limpiar valor actual
        current = self._get_variable(index)
        self.state -= current * self.var_masks[index]
        # Establecer nuevo valor
        self.state += (value % self.base) * self.var_masks[index]
    
    def _get_controller(self, index):
        """Obtiene el estado del controlador."""
        return (self.state // self.ctrl_masks[index]) % self.base
    
    def _set_controller(self, index, value):
        """Establece el estado del controlador."""
        current = self._get_controller(index)
        self.state -= current * self.ctrl_masks[index]
        self.state += (value % self.base) * self.ctrl_masks[index]
    
    def add_to_variable(self, index, delta):
        """
        Añade un valor a una variable y procesa automáticamente
        el acarreo y las reglas de interacción.
        """
        current_val = self._get_variable(index)
        current_ctrl = self._get_controller(index)
        
        # Aplicar cambio
        new_val = (current_val + delta) % self.base
        self._set_variable(index, new_val)
        
        # Detectar desbordamiento (controlador != ctrl_value)
        if current_ctrl != self.ctrl_value:
            # Aquí aplicas tus reglas if-less
            # Ejemplo: si X desborda, afecta a Y y Z
            self._apply_overflow_rules(index, delta)
            
            # Restaurar controlador
            self._set_controller(index, self.ctrl_value)
    
    def _apply_overflow_rules(self, changed_index, delta):
        """
        Aplica reglas de interacción entre variables cuando hay desbordamiento.
        Esta es la parte 'if-less' mágica del Numeraso.
        """
        # EJEMPLO: Reglas para sistema BHL (Bondad, Hostilidad, Lógica)
        if self.num_vars == 3:  # Sistema BHL
            B, H, L = 0, 1, 2  # Índices
            
            if changed_index == B:  # Cambió Bondad
                # Regla: Si Bondad aumenta, Lógica disminuye
                self._set_variable(L, (self._get_variable(L) - 1) % self.base)
                
            elif changed_index == H:  # Cambió Hostilidad
                # Regla: Si Hostilidad aumenta, Bondad disminuye
                self._set_variable(B, (self._get_variable(B) - 1) % self.base)
                
            elif changed_index == L:  # Cambió Lógica
                # Regla: Si Lógica aumenta, Hostilidad aumenta
                self._set_variable(H, (self._get_variable(H) + 1) % self.base)
    
    def get_all_variables(self):
        """Devuelve todas las variables como lista."""
        return [self._get_variable(i) for i in range(self.num_vars)]
    
    def get_state_string(self):
        """Representación visual del estado Numeraso."""
        parts = []
        for i in range(self.num_vars - 1, -1, -1):
            parts.append(str(self._get_controller(i)))
            parts.append(str(self._get_variable(i)).zfill(int(math.log10(self.base))))
        return "".join(parts)
    
    def __str__(self):
        return f"Numeraso(base={self.base}, state={self.get_state_string()})"


