"""
NUMERASO BINARIO - VERSIÓN DE ALTO RENDIMIENTO
Usando operaciones bitwise para velocidad de hardware
"""

class BinaryNumeraso:
    """
    Numeraso en binario para máximo rendimiento.
    Usa operaciones bitwise en lugar de aritmética.
    """
    
    def __init__(self, bits_per_var=8, num_vars=3):
        self.bits = bits_per_var
        self.num_vars = num_vars
        self.ctrl_bit = 1 << (bits_per_var - 1)  # Bit más significativo como controlador
        
        # Máscaras para cada variable
        self.var_masks = []
        self.ctrl_masks = []
        
        shift = 0
        for i in range(num_vars):
            # Máscara para la variable (bits de datos)
            var_mask = ((1 << bits_per_var) - 1) << shift
            self.var_masks.append(var_mask)
            shift += bits_per_var
            
            # Máscara para el controlador (1 bit)
            ctrl_mask = 1 << shift
            self.ctrl_masks.append(ctrl_mask)
            shift += 1
        
        self.state = 0
        
        # Inicializar todos los controladores a 1
        for i in range(num_vars):
            self.state |= self.ctrl_masks[i]
    
    def get_var(self, index):
        """Obtiene variable usando operaciones bitwise."""
        return (self.state & self.var_masks[index]) >> (index * (self.bits + 1))
    
    def set_var(self, index, value):
        """Establece variable usando operaciones bitwise."""
        # Limpiar bits actuales
        self.state &= ~self.var_masks[index]
        # Establecer nuevos bits
        masked_value = (value & ((1 << self.bits) - 1))
        self.state |= (masked_value << (index * (self.bits + 1)))
    
    def add_to_var(self, index, delta):
        """
        Añade delta a variable con detección de overflow bitwise.
        Implementación ultra-rápida.
        """
        current = self.get_var(index)
        new_value = current + delta
        
        # Extraer bits de overflow
        overflow = new_value >> self.bits
        final_value = new_value & ((1 << self.bits) - 1)
        
        # Establecer nuevo valor
        self.set_var(index, final_value)
        
        # Verificar controlador (bit más significativo de la posición)
        ctrl_bit_set = (self.state & self.ctrl_masks[index]) != 0
        
        if overflow or not ctrl_bit_set:
            # Aplicar reglas if-less con operaciones bitwise
            self._apply_bitwise_rules(index, overflow)
            
            # Restablecer controlador
            self.state |= self.ctrl_masks[index]
    
    def _apply_bitwise_rules(self, changed_index, overflow):
        """
        Reglas if-less implementadas con operaciones bitwise.
        Cada regla es una serie de operaciones AND, OR, SHIFT.
        """
        # Ejemplo: Sistema de tres variables con reglas simples
        if self.num_vars == 3:
            if changed_index == 0:  # Variable 0 cambió
                # Regla: Si V0 overflow, incrementar V1
                v1 = self.get_var(1)
                self.set_var(1, v1 + 1)
                
            elif changed_index == 1:  # Variable 1 cambió
                # Regla: Si V1 overflow, decrementar V2
                v2 = self.get_var(2)
                self.set_var(2, max(0, v2 - 1))
    
    def __str__(self):
        """Representación binaria legible."""
        result = []
        total_bits = self.num_vars * (self.bits + 1)
        
        for i in range(self.num_vars - 1, -1, -1):
            ctrl_bit = "1" if (self.state & self.ctrl_masks[i]) else "0"
            var_bits = format(self.get_var(i), f'0{self.bits}b')
            result.append(f"[{ctrl_bit}{var_bits}]")
        
        return f"BinaryNumeraso: {' '.join(result)}"


