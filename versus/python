"""
SISTEMA BHL LIMPIO USANDO NUMERASO
Bondad, Hostilidad, Lógica con sombras y deseos
"""

class BHLPersonality:
    """
    Sistema de personalidad basado en Numeraso.
    Implementa Bondad, Hostilidad, Lógica con sombras Jungianas.
    """
    
    def __init__(self, base=1000):
        # Sistema principal BHL
        self.bhl = Numeroso(base=base, num_variables=3, initial_values=[50, 50, 50])
        
        # Experiencias (acumuladores)
        self.exp = [0, 0, 0]  # ExpB, ExpH, ExpL
        
        # Sistema sombra (opuestos)
        self.shadow = [0, 0, 0]
        
        # Sistema deseos (tensiones)
        self.desire = [0, 0, 0]
        
        # Necesidades biológicas (CHS)
        self.needs = Numeroso(base=base, num_variables=3, initial_values=[50, 50, 50])
        self.needs_exp = [0, 0, 0]  # ExpC, ExpH, ExpS
    
    def update_from_input(self, bondad_delta, hostilidad_delta, logica_delta):
        """
        Actualiza el sistema basado en input externo.
        Implementa las reglas de interacción BHL.
        """
        # Aplicar cambios con reglas if-less integradas
        if bondad_delta != 0:
            self.bhl.add_to_variable(0, bondad_delta)
            self.exp[0] += abs(bondad_delta)
            
        if hostilidad_delta != 0:
            self.bhl.add_to_variable(1, hostilidad_delta)
            self.exp[1] += abs(hostilidad_delta)
            
        if logica_delta != 0:
            self.bhl.add_to_variable(2, logica_delta)
            self.exp[2] += abs(logica_delta)
        
        # Actualizar sombras y deseos
        self._update_shadows()
        self._update_desires()
        
        # Afectar necesidades biológicas
        self._affect_needs()
    
    def _update_shadows(self):
        """Calcula las sombras Jungianas (opuestos)."""
        base = self.bhl.base
        values = self.bhl.get_all_variables()
        self.shadow = [base - val for val in values]
    
    def _update_desires(self):
        """Calcula deseos como tensión entre expresión y sombra."""
        values = self.bhl.get_all_variables()
        self.desire = [
            abs(self.shadow[i] - values[i]) - self.exp[i] // 10
            for i in range(3)
        ]
    
    def _affect_needs(self):
        """Las emociones afectan las necesidades biológicas."""
        values = self.bhl.get_all_variables()
        
        # Ejemplo: Alta hostilidad reduce hambre
        hostilidad = values[1]
        if hostilidad > 70:
            self.needs.add_to_variable(1, -5)  # Reduce hambre
        
        # Alta lógica aumenta necesidad de sueño
        logica = values[2]
        if logica > 70:
            self.needs.add_to_variable(2, 5)  # Aumenta sueño
    
    def get_personality_vector(self):
        """Vector compacto de toda la personalidad."""
        bhl_vals = self.bhl.get_all_variables()
        return {
            'bondad': bhl_vals[0],
            'hostilidad': bhl_vals[1],
            'logica': bhl_vals[2],
            'sombra_bondad': self.shadow[0],
            'sombra_hostilidad': self.shadow[1],
            'sombra_logica': self.shadow[2],
            'deseo_bondad': self.desire[0],
            'deseo_hostilidad': self.desire[1],
            'deseo_logica': self.desire[2],
            'necesidades': self.needs.get_all_variables()
        }


