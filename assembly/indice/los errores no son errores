; Función hash más robusta para nombres de variables
hash_variable:
    xor rax, rax
    mov rcx, 0          ; contador
.hash_loop:
    mov dl, [rsi+rcx]   ; carácter actual
    test dl, dl
    jz .done
    rol rax, 5          ; rotar left 5 bits
    xor al, dl          ; XOR con el carácter
